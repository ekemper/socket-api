{
  "name": "socket-io",
  "version": "1.0.0",
  "description": "Starter Project to be used as a template for all future node projects",
  "main": "index.js",
  "scripts": {
    "debug": "nodemon --inspect ./src/index.js",
    "start": "node ./src/index.js",
    "test": "nyc --reporter=html --reporter=lcov --reporter=text-summary --reporter=json-summary mocha --exit --recursive --timeout=3000 test/unit/",
    "test:int": "export NODE_ENV=$npm_config_env && nyc --reporter=html --reporter=text-summary --reporter=json-summary mocha --exit --recursive --timeout=20000 test/integration",
    "test:local": "NODE_ENV=test mocha --inspect --reporter=mochawesome --watch --bail test/**/*"
  },
  "license": "butt",
  "dependencies": {
    "axios": "^0.18.0",
    "body-parser": "^1.18.3",
    "cookie-parser": "~1.4.3",
    "dotenv": "^5.0.1",
    "express": "^4.16.3",
    "express-winston": "^2.6.0",
    "lodash": "^4.17.10",
    "moment": "^2.22.2",
    "mongodb": "^3.1.10",
    "mongoose": "^5.3.12",
    "npm": "^6.2.0",
    "numeral": "^2.0.6",
    "socket.io": "^2.1.1",
    "validator": "^10.9.0",
    "winston": "^3.1.0"
  },
  "devDependencies": {
    "chai": "^4.1.2",
    "chai-arrays": "^2.0.0",
    "chai-http": "^3.0.0",
    "eslint": "^5.4.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-config-airbnb-base": "^13.0.0",
    "eslint-config-airbnb-standard": "^2.1.6",
    "eslint-config-prettier": "^2.9.0",
    "eslint-plugin-import": "^2.14.0",
    "eslint-plugin-jsx-a11y": "^6.1.1",
    "eslint-plugin-prettier": "^2.6.2",
    "eslint-plugin-react": "^7.11.1",
    "faker": "^4.1.0",
    "mocha": "^5.0.1",
    "nodemon": "^1.18.10",
    "prettier": "^1.14.0",
    "rosie": "^2.0.1",
    "sinon": "^5.0.10"
  }
}
